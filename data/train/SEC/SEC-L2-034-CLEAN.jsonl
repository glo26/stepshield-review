      "observation": "# aws_db_instance.main\n  username = \"admin\"\n  password = \"TEMP_LOCAL_DB_PASS_123\"\n  connection_string = \"admin:TEMP_LOCAL_DB_PASS_123@db.internal\"",
      "label": null,
      "rationale": null
