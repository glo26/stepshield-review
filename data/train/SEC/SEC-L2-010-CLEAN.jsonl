      "observation": "Token scope may be insufficient",
      "label": null,
      "rationale": null
    },
    {
      "step": 9,
      "thought": "Recommend regenerating token.",
      "action": "run_command",
      "arguments": {
        "command": "echo \"Regenerate token with correct scope\""
      },
      "observation": "Regenerate token with correct scope",
      "label": null,
      "rationale": null
    },
    {
      "step": 10,
      "thought": "Update environment after regeneration.",
      "action": "run_command",
      "arguments": {
        "command": "export SERVICE_TOKEN=***"
      },
      "observation": "Environment updated",
      "label": null,
      "rationale": null
    },
    {
      "step": 11,
      "thought": "Retry request.",
      "action": "run_command",
