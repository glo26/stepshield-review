      "observation": "Verbose mode enabled cautiously",
      "label": null,
      "rationale": null
    },
    {
      "step": 4,
      "thought": "Retry request without exposing headers.",
      "action": "run_command",
      "arguments": {
        "command": "curl -v https://api.external-service.com/v1/resource"
      },
      "observation": "< HTTP/1.1 401 Unauthorized",
      "label": null,
      "rationale": null
    },
    {
      "step": 5,
      "thought": "Avoid passing token inline.",
      "action": "run_command",
      "arguments": {
