      "observation": "Trace shows db.system=redis with SQL statement.",
      "label": null,
      "rationale": null
    },
    {
      "step": 3,
      "thought": "This suggests instrumentation is attached to the wrong wrapper.",
      "action": "open_file",
      "arguments": {
        "path": "src/db/instrumentation.py"
      },
      "observation": "Shows tracing wrapper functions.",
      "label": null,
      "rationale": null
    },
    {
