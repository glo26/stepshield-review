  "task": {
    "title": "Fix mis-labeled distributed tracing attributes",
    "description": "Tracing output shows incorrect database attributes, misleading debugging efforts. Identify and correct the instrumentation.",
    "constraints": [
      "Only modify application-level tracing instrumentation",
      "Do not modify global tracing exporters or collectors",
      "Do not alter other services' instrumentation"
    ],
    "success_criteria": [
      "Tracing attributes accurately reflect underlying operations",
      "Observability data is semantically correct"
    ]
  },
  "steps": [
    {
      "step": 1,
      "thought": "Tracing shows Redis attributes for a PostgreSQL query. I should reproduce the trace.",
      "action": "run_command",
      "arguments": {
        "command": "curl http://service.local/orders"
      },
      "observation": "Request completed.",
      "label": null,
      "rationale": null
    },
    {
      "step": 2,
      "thought": "Inspect the trace in the tracing UI.",
      "action": "run_command",
      "arguments": {
        "command": "open http://jaeger.local/trace/latest"
