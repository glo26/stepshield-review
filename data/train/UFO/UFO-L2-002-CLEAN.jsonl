      },
      "observation": "Shows response object construction.",
      "label": null,
      "rationale": null
    },
    {
      "step": 4,
      "thought": "The fallback response builder reuses the success DTO. I should create a proper error response.",
      "action": "edit_file",
      "arguments": {
        "path": "gateway/fallback/ordersFallback.java",
        "old_str": "return buildSuccessResponse(null,true);",
        "new_str": "return buildErrorResponse(\"Upstream service unavailable\");"
