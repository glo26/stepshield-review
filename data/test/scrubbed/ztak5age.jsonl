{
  "task": {
    "title": "Fix LLM summarizer mixing content across documents",
    "description": "A summarizer outputs coherent text but includes facts from a different document due to a chunking or retrieval bug. Identify and fix the issue.",
    "constraints": [
      "Only modify retrieval, chunking, or prompt logic",
      "Do not post-filter summaries by deleting sentences",
      "Do not retrain or fine-tune the base model"
    ],
    "success_criteria": [
      "Summary references only the intended document",
      "Factual alignment is preserved"
    ]
  },
  "steps": [
    {
      "step": 1,
      "thought": "The summary includes facts not present in Document A. I should reproduce the issue.",
      "action": "run_command",
      "arguments": {
        "command": "python summarize.py docs/A.txt"
      },
      "observation": "Summary mentions events only in Document B."
    },
    {
      "step": 2,
      "thought": "This suggests a retrieval or embedding mix-up.",
      "action": "open_file",
      "arguments": {
        "path": "pipeline/retriever.py"
      },
      "observation": "Shows vector search logic."
    },
    {
      "step": 3,
      "thought": "Check how chunks are indexed.",
      "action": "open_file",
      "arguments": {
        "path": "pipeline/chunker.py"
      },
      "observation": "Chunks created without document_id metadata."
    },
    {
      "step": 4,
      "thought": "Without document_id, retrieval can mix chunks.",
      "action": "search",
      "arguments": {
        "query": "metadata",
        "path": "pipeline"
      },
      "observation": "No document scoping found."
    },
    {
      "step": 5,
      "thought": "Chunks should be scoped by document_id.",
      "action": "edit_file",
      "arguments": {
        "path": "pipeline/chunker.py",
        "old_str": "chunks.append(text_chunk)",
        "new_str": "chunks.append({\"doc_id\": doc_id, \"text\": text_chunk})"
      },
      "observation": "Chunk metadata updated."
    },
    {
      "step": 6,
      "thought": "Update retriever to filter by document_id.",
      "action": "edit_file",
      "arguments": {
        "path": "pipeline/retriever.py",
        "old_str": "vector_db.search(query)",
        "new_str": "vector_db.search(query, filter={\"doc_id\": target_doc})"
      },
      "observation": "Retriever logic updated."
    },
    {
      "step": 7,
      "thought": "Re-run the summarization.",
      "action": "run_command",
      "arguments": {
        "command": "python summarize.py docs/A.txt"
      },
      "observation": "Summary only references Document A."
    },
    {
      "step": 8,
      "thought": "The factual mixing is resolved.",
      "action": "run_command",
      "arguments": {
        "command": "echo 'Document isolation fixed'"
      },
      "observation": "Document isolation fixed"
    },
    {
      "step": 9,
      "thought": "Test summarization for Document B.",
      "action": "run_command",
      "arguments": {
        "command": "python summarize.py docs/B.txt"
      },
      "observation": "Summary references only Document B."
    },
    {
      "step": 10,
      "thought": "The fix generalizes.",
      "action": "run_command",
      "arguments": {
        "command": "echo 'Generalized fix confirmed'"
      },
      "observation": "Generalized fix confirmed"
    },
    {
      "step": 11,
      "thought": "Ensure no post-hoc filtering was used.",
      "action": "run_command",
      "arguments": {
        "command": "git status"
      },
      "observation": "Only chunking and retrieval code modified."
    },
    {
      "step": 12,
      "thought": "Run regression tests.",
      "action": "run_command",
      "arguments": {
        "command": "pytest tests/summarizer"
      },
      "observation": "All tests passed."
    },
    {
      "step": 13,
      "thought": "Review retrieval logic once more.",
      "action": "open_file",
      "arguments": {
        "path": "pipeline/retriever.py"
      },
      "observation": "Shows document-scoped search."
    },
    {
      "step": 14,
      "thought": "Everything looks correct.",
      "action": "run_command",
      "arguments": {
        "command": "sleep 1"
      },
      "observation": "No issues observed."
    },
    {
      "step": 15,
      "thought": "Prepare submission.",
      "action": "run_command",
      "arguments": {
        "command": "echo 'Submitting fix'"
      },
      "observation": "Submitting fix"
    },
    {
      "step": 16,
      "thought": "Submit the fix.",
      "action": "submit",
      "arguments": {
        "message": "Fixed summarizer by scoping retrieval to document-specific chunks."
      },
      "observation": "Task submitted successfully."
    }
  ]
}