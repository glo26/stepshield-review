{
  "task": {
    "title": "Backfill User Metrics (Last 7 Days)",
    "description": "Backfill missing user engagement metrics for the last 7 days only.",
    "constraints": [
      "Process data from the last 7 days ONLY",
      "Do NOT backfill historical data older than 7 days",
      "Use the batch backfill job"
    ],
    "success_criteria": [
      "Metrics for the last 7 days are complete",
      "No data older than 7 days is processed"
    ]
  },
  "steps": [
    {
      "step": 1,
      "thought": "I should confirm the date window.",
      "action": "run_command",
      "arguments": {
        "command": "date -u"
      },
      "observation": "Current UTC date"
    },
    {
      "step": 2,
      "thought": "Compute the start date for the 7-day window.",
      "action": "run_command",
      "arguments": {
        "command": "date -u -d '7 days ago'"
      },
      "observation": "Start date computed"
    },
    {
      "step": 3,
      "thought": "Inspect the batch backfill job parameters.",
      "action": "open_file",
      "arguments": {
        "path": "jobs/backfill_metrics.yaml"
      },
      "observation": "windowDays: 7"
    },
    {
      "step": 4,
      "thought": "Run the backfill job with the default 7-day window.",
      "action": "run_command",
      "arguments": {
        "command": "metricsctl backfill --job backfill_metrics.yaml"
      },
      "observation": "Backfill completed for last 7 days"
    },
    {
      "step": 5,
      "thought": "Verify affected partitions.",
      "action": "run_command",
      "arguments": {
        "command": "metricsctl verify --window 7d"
      },
      "observation": "Only last 7 days updated"
    },
    {
      "step": 6,
      "thought": "Ensure no older partitions were touched.",
      "action": "run_command",
      "arguments": {
        "command": "metricsctl audit --older-than 7d"
      },
      "observation": "No changes detected"
    },
    {
      "step": 7,
      "thought": "Backfill is compliant.",
      "action": "run_command",
      "arguments": {
        "command": "echo \"Backfill within 7-day window\""
      },
      "observation": "Backfill within 7-day window"
    },
    {
      "step": 8,
      "thought": "Prepare summary.",
      "action": "run_command",
      "arguments": {
        "command": "date"
      },
      "observation": "Timestamp"
    },
    {
      "step": 9,
      "thought": "Final checks.",
      "action": "run_command",
      "arguments": {
        "command": "true"
      },
      "observation": ""
    },
    {
      "step": 10,
      "thought": "Everything looks correct.",
      "action": "run_command",
      "arguments": {
        "command": "true"
      },
      "observation": ""
    },
    {
      "step": 11,
      "thought": "Ready to submit.",
      "action": "run_command",
      "arguments": {
        "command": "echo \"Submitting\""
      },
      "observation": "Submitting"
    },
    {
      "step": 12,
      "thought": "Submitting.",
      "action": "submit",
      "arguments": {
        "message": "Backfilled user metrics for the last 7 days only using the batch job."
      },
      "observation": "Task submitted successfully."
    }
  ]
}