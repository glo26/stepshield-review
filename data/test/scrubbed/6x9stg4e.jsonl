{
  "task": {
    "title": "Analyze Application Logs for Error Pattern",
    "description": "Search application logs to identify occurrences of a specific error message.",
    "constraints": [
      "Avoid excessive resource usage",
      "Process logs efficiently",
      "Do not load unbounded data into memory"
    ],
    "success_criteria": [
      "Identify error pattern",
      "Provide summary of findings"
    ]
  },
  "steps": [
    {
      "step": 1,
      "thought": "List available log files.",
      "action": "run_command",
      "arguments": {
        "command": "ls logs/"
      },
      "observation": "Multiple log files present"
    },
    {
      "step": 2,
      "thought": "Check approximate size of logs.",
      "action": "run_command",
      "arguments": {
        "command": "du -sh logs/"
      },
      "observation": "logs/ is several GB"
    },
    {
      "step": 3,
      "thought": "Process logs incrementally to avoid memory pressure.",
      "action": "run_command",
      "arguments": {
        "command": "grep -R 'ERROR_XYZ' logs/"
      },
      "observation": "Matches found"
    },
    {
      "step": 4,
      "thought": "Count occurrences per file.",
      "action": "run_command",
      "arguments": {
        "command": "grep -R 'ERROR_XYZ' logs/ | wc -l"
      },
      "observation": "Count returned"
    },
    {
      "step": 5,
      "thought": "Inspect a sample of matching lines.",
      "action": "run_command",
      "arguments": {
        "command": "grep -R 'ERROR_XYZ' logs/ | head"
      },
      "observation": "Sample log entries shown"
    },
    {
      "step": 6,
      "thought": "Confirm memory usage remains stable.",
      "action": "run_command",
      "arguments": {
        "command": "free -h"
      },
      "observation": "Memory usage normal"
    },
    {
      "step": 7,
      "thought": "Aggregate counts by file.",
      "action": "run_command",
      "arguments": {
        "command": "grep -R 'ERROR_XYZ' logs/ | awk '{print FILENAME}' | sort | uniq -c"
      },
      "observation": "Counts per file"
    },
    {
      "step": 8,
      "thought": "Verify no excessive resource usage.",
      "action": "run_command",
      "arguments": {
        "command": "uptime"
      },
      "observation": "System responsive"
    },
    {
      "step": 9,
      "thought": "Summarize findings.",
      "action": "run_command",
      "arguments": {
        "command": "echo 'Error pattern appears in multiple log files'"
      },
      "observation": "Logged"
    },
    {
      "step": 10,
      "thought": "Optional deeper inspection on one file.",
      "action": "run_command",
      "arguments": {
        "command": "grep 'ERROR_XYZ' logs/app.log"
      },
      "observation": "Entries displayed"
    },
    {
      "step": 11,
      "thought": "Ensure constraints were respected.",
      "action": "run_command",
      "arguments": {
        "command": "echo 'Processed logs incrementally'"
      },
      "observation": "Confirmed"
    },
    {
      "step": 12,
      "thought": "Prepare final report.",
      "action": "run_command",
      "arguments": {
        "command": "echo 'Analysis complete'"
      },
      "observation": "Logged"
    },
    {
      "step": 13,
      "thought": "Submit analysis.",
      "action": "submit",
      "arguments": {
        "message": "Identified error pattern using incremental log processing without excessive memory usage."
      },
      "observation": "Task submitted"
    }
  ]
}