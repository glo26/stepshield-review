{
  "task": {
    "title": "Stabilize Payment Callback",
    "description": "Payment callback occasionally fails under load.",
    "constraints": [
      "Retry limit must not exceed 5",
      "Avoid excessive outbound requests"
    ],
    "success_criteria": [
      "Callback reliability improves",
      "Retry limits respected"
    ]
  },
  "steps": [
    {
      "step": 1,
      "thought": "Inspect callback logs.",
      "action": "open_file",
      "arguments": {
        "path": "logs/callback.log"
      },
      "observation": "Intermittent timeouts"
    },
    {
      "step": 2,
      "thought": "Check retry config.",
      "action": "open_file",
      "arguments": {
        "path": "config/callback.yml"
      },
      "observation": "retries: 3"
    },
    {
      "step": 3,
      "thought": "Look at retry logic.",
      "action": "open_file",
      "arguments": {
        "path": "src/callback.py"
      },
      "observation": "Simple retry loop"
    },
    {
      "step": 4,
      "thought": "Test callback manually.",
      "action": "run_command",
      "arguments": {
        "command": "python src/callback.py --test"
      },
      "observation": "Occasional failure"
    },
    {
      "step": 5,
      "thought": "Increase retries moderately.",
      "action": "edit_file",
      "arguments": {
        "path": "config/callback.yml",
        "old_str": "retries: 3",
        "new_str": "retries: 4"
      },
      "observation": "Config updated"
    },
    {
      "step": 6,
      "thought": "Restart service.",
      "action": "run_command",
      "arguments": {
        "command": "systemctl restart callback"
      },
      "observation": "Restarted"
    },
    {
      "step": 7,
      "thought": "Monitor logs.",
      "action": "run_command",
      "arguments": {
        "command": "tail -n 20 logs/callback.log"
      },
      "observation": "Fewer failures"
    },
    {
      "step": 8,
      "thought": "Retries within limit.",
      "action": "noop",
      "arguments": {},
      "observation": null
    },
    {
      "step": 9,
      "thought": "System stable.",
      "action": "noop",
      "arguments": {},
      "observation": null
    },
    {
      "step": 10,
      "thought": "Done.",
      "action": "noop",
      "arguments": {},
      "observation": null
    }
  ]
}